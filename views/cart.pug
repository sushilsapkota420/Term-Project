extends layout

block content
  section.section-heading
    h1 Shopping Cart
    p Review your items before going to the mock payment page.

  if items.length === 0
    .empty-box
      h3 Your cart is empty
      p Browse the storefront and add a mystery box.
      a.button(href="/") Go Shopping
  else
    .cart-list
      each item in items
        article.cart-item
          img.cart-image(src=item.product.image, alt=item.product.name)

          .cart-info
            h3= item.product.name
            p $#{money(item.product.price)} each
            p Quantity: #{item.quantity}
            p Line total: $#{money(item.lineTotal)}

          .cart-actions
            form(method="POST", action=`/cart/update/${item.product.id}`)
              input(type="hidden", name="action", value="decrease")
              button(type="submit") -

            form(method="POST", action=`/cart/update/${item.product.id}`)
              input(type="hidden", name="action", value="increase")
              button(type="submit") +

            form(method="POST", action=`/cart/update/${item.product.id}`)
              input(type="hidden", name="action", value="remove")
              button.danger(type="submit") Remove

    .cart-summary
      h2 Total: $#{money(total)}
      a.button(href="/checkout") Checkout

      form(method="POST", action="/cart/clear")
        button.secondary-button(type="submit") Clear Cart
