extends layout

block content
  section.form-card
    h1 Login
    p Log in to checkout and view your purchase history.

    form(method="POST", action="/login")
      label(for="email") Email
      input#email(type="email", name="email", placeholder="ava@example.com", required)

      label(for="password") Password
      input#password(type="password", name="password", placeholder="Your password", required)

      button.button(type="submit") Login

    p.small-text
      | New here? 
      a(href="/register") Create an account
      | .
